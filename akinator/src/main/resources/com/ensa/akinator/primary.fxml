<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="750.0" prefWidth="500.0" stylesheets="@styles/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ensa.akinator.controllers.PrimaryController">

    <children>
        <VBox alignment="CENTER" spacing="30.0" styleClass="main-container">
            <children>
                <VBox alignment="CENTER" spacing="15.0" styleClass="button-container">
                    <ImageView fitHeight="296.0" fitWidth="238.0" pickOnBounds="true"
                        preserveRatio="true" styleClass="logo">
                        <image>
                            <Image url="@assets/akinator.png" />
                        </image>
                    </ImageView>

                    <Label styleClass="subtitle"
                        text="Think of a character and I'll guess who it is..." textFill="#c0c0c0">
                        <font>
                            <Font name="Georgia Italic" size="16.0" />
                        </font>
                        <VBox.margin>
                            <Insets bottom="16.0" />
                        </VBox.margin>
                    </Label>
                    <Button fx:id="playButton" mnemonicParsing="false" onAction="#handlePlayAction"
                        styleClass="primary-btn" text="▶  Play vs Akinator" />
                    <Button fx:id="playButton1" mnemonicParsing="false" onAction="#handlePlayAction"
                        styleClass="ai-btn" text="🤖  Play vs AI" />
                </VBox>

                <Label prefHeight="27.0" prefWidth="110.0" styleClass="footer"
                    text="BY ANAS &amp; YOUNES" textFill="#a0a0a0" />
            </children>
        </VBox>
    </children>
</StackPane>