<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="750.0" prefWidth="500.0" stylesheets="@styles/game.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ensa.akinator.controllers.GameController">
    <children>
        <VBox alignment="TOP_CENTER" spacing="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <children>
                <HBox alignment="CENTER" styleClass="progress-bar">
                    <children>
                        <Label fx:id="stepLabel" styleClass="progress-text" text="QUESTION N° 1">
                            <font>
                                <Font name="Impact" size="14.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <VBox alignment="CENTER" VBox.vgrow="ALWAYS" styleClass="main-container">
                    <children>
                        <VBox alignment="CENTER" spacing="20.0">
                            <children>
                                <ImageView fx:id="genieImage" fitHeight="300.0" fitWidth="240.0" pickOnBounds="true" preserveRatio="true" styleClass="genie-image">
                                    <image>
                                        <Image url="@assets/akinator-ask.png" />
                                    </image>
                                </ImageView>
                                
                                <VBox alignment="CENTER">
                                    <children>
                                        <VBox alignment="CENTER" styleClass="question-bubble">
                                            <children>
                                                <Label fx:id="questionLabel" styleClass="question-text" text="Is your character a man?" textAlignment="CENTER" wrapText="true" />
                                            </children>
                                        </VBox>
                                        <Region styleClass="bubble-tail" maxWidth="30" maxHeight="20" />
                                    </children>
                                </VBox>

                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox alignment="BOTTOM_CENTER" spacing="12.0" styleClass="buttons-container">
                    <children>
                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <Button onAction="#onYesClicked" styleClass="akinator-btn, main-btn" text="Yes" />
                                <Button onAction="#onNoClicked" styleClass="akinator-btn, main-btn" text="No" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Button onAction="#onProbablyClicked" styleClass="akinator-btn, sub-btn" text="Probably" />
                                <Button onAction="#onDontKnowClicked" styleClass="akinator-btn, sub-btn" text="Don't know" />
                                <Button onAction="#onProbablyNotClicked" styleClass="akinator-btn, sub-btn" text="Probably not" />
                            </children>
                        </HBox>
                    </children>
                    <VBox.margin>
                        <Insets bottom="30.0" />
                    </VBox.margin>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
