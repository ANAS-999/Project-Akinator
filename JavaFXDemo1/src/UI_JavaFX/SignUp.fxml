<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox styleClass="root-vbox"
      alignment="CENTER"
      prefHeight="630.0" prefWidth="350.0"
      stylesheets="@../resources/style.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="UI_JavaFX.SignUpFXMLController">
    <children>

        <!-- Titre -->
        <Label text="Create account" styleClass="label-title">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <!-- Champ Nom -->
        <VBox styleClass="field-group" alignment="CENTER" spacing="6">
            <children>
                <Label text="Nom :" />
                <TextField fx:id="nomField" promptText="Enter your name" maxWidth="Infinity" />
            </children>
        </VBox>

        <!-- Champ Username -->
        <VBox styleClass="field-group" alignment="CENTER" spacing="6">
            <children>
                <Label text="Username :" />
                <TextField fx:id="userField" promptText="Choose a username" maxWidth="Infinity" />
            </children>
        </VBox>

        <!-- Champ Password -->
        <VBox styleClass="field-group" alignment="CENTER" spacing="6">
            <children>
                <Label text="Password :" />
                <PasswordField fx:id="passField" promptText="Create password" maxWidth="Infinity" />
            </children>
        </VBox>

        <!-- Bouton -->
        <Button fx:id="signUpButton"
                onAction="#handleSignUp"
                text="S'inscrire"
                maxWidth="Infinity" />

        <!-- Lien connexion -->
        <Hyperlink onAction="#goToLogin" text="Deja un compte ? Se connecter" />

    </children>
</VBox>