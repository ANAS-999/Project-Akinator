<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="630.0" prefWidth="350.0" spacing="10.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="UI_JavaFX.SignUpFXMLController">
    <children>
        <Label text="Create account">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>

        <VBox alignment="CENTER" fillWidth="false">
            <children>
                <Label text="Nom :" />
                <TextField fx:id="nomField" promptText="Enter your name" />
            </children>
        </VBox>

        <VBox alignment="CENTER" fillWidth="false">
            <children>
                <Label text="Username :" />
                <TextField fx:id="userField" promptText="Chose a username" />
            </children>
        </VBox>

        <VBox alignment="CENTER" fillWidth="false">
            <children>
                <Label text="Password :" />
                <PasswordField fx:id="passField" prefHeight="25.0" prefWidth="151.0" promptText="Create password" />
            </children>
        </VBox>

        <Button fx:id="signUpButton" onAction="#handleSignUp" text="S'inscrire" />

        <Hyperlink onAction="#goToLogin" text="Déjà un compte ? Se connecter" />
    </children>
</VBox>
