<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox styleClass="root-vbox"
      alignment="CENTER"
      prefHeight="630.0" prefWidth="350.0"
      stylesheets="@../resources/style.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="UI_JavaFX.LoginFXMLController">
    <children>

        <!-- Logo Akinator -->
        <ImageView fitHeight="272.0" fitWidth="230.0" preserveRatio="true" pickOnBounds="true">
            <image>
                <Image url="@../assets/Logo_Akinator-removebg-preview.png" />
            </image>
        </ImageView>

        <!-- Champ Username -->
        <VBox styleClass="field-group" alignment="CENTER" spacing="6">
            <children>
                <Label text="UserName :" />
                <TextField fx:id="userField" promptText="Enter username" maxWidth="Infinity" />
            </children>
        </VBox>

        <!-- Champ Password -->
        <VBox styleClass="field-group" alignment="CENTER" spacing="6">
            <children>
                <Label text="Password :" />
                <PasswordField fx:id="passField" promptText="Enter password" maxWidth="Infinity" />
            </children>
        </VBox>

        <!-- Bouton Login -->
        <Button fx:id="loginbtn"
                onAction="#handleLogin"
                text="Se connecter"
                maxWidth="Infinity" />

        <!-- Lien vers SignUp -->
        <Hyperlink onAction="#goToSignUp" text="Pas de compte ? S'inscrire" />

    </children>
</VBox>