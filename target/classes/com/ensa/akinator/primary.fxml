<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="750.0" prefWidth="500.0" stylesheets="@styles/primary.css" xmlns="http://javafx.com/javafx/26"
           xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ensa.akinator.Controllers.PrimaryController">

    <children>
        <VBox alignment="CENTER" spacing="30.0" styleClass="main-container">
            <children>
                <VBox alignment="CENTER" spacing="15.0" styleClass="button-container">
                    <ImageView fitHeight="296.0" fitWidth="238.0" pickOnBounds="true"
                               preserveRatio="true" styleClass="logo">
                        <image>
                            <Image url="@assets/akinator.png"/>
                        </image>
                    </ImageView>

                    <Label styleClass="subtitle"
                           text="Think of a character and I'll guess who it is..." textFill="#c0c0c0">
                        <font>
                            <Font name="Georgia Italic" size="16.0"/>
                        </font>
                        <VBox.margin>
                            <Insets bottom="16.0"/>
                        </VBox.margin>
                    </Label>

                    <Button fx:id="playButton" mnemonicParsing="false" onAction="#handlePlayAction"
                            styleClass="primary-btn" text="▶  Play vs Akinator"/>
                    <Button fx:id="playButton1" mnemonicParsing="false" onAction="#handlePlayAIAction"
                            styleClass="ai-btn" text="🤖  Play vs AI"/>

                    <!-- Bouton pour voir l'historique / leaderboard -->
                    <Button fx:id="historyButton" mnemonicParsing="false" onAction="#handleHistoryAction"
                            styleClass="ai-btn" text="🏆  Leaderboard"/>

                    <!-- Label d'avertissement de connexion -->
                    <Label fx:id="loginWarningLabel" styleClass="warning-label" text="" visible="false" managed="false" />
                </VBox>
            </children>
        </VBox>
        <Button fx:id="musicButton" mnemonicParsing="false" onAction="#handleMusicToggle"
                styleClass="music-btn-icon" text="🔊" StackPane.alignment="TOP_RIGHT">
            <StackPane.margin>
                <Insets top="20.0" right="74.0"/>
            </StackPane.margin>
        </Button>
        <Button fx:id="infoButton" mnemonicParsing="false" onAction="#handleInfoAction"
                styleClass="info-btn-icon" text="ℹ" StackPane.alignment="TOP_RIGHT">
            <StackPane.margin>
                <Insets top="20.0" right="20.0"/>
            </StackPane.margin>
        </Button>
        <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLoginAction"
                styleClass="login-btn-icon" text="👤" StackPane.alignment="TOP_LEFT">
            <StackPane.margin>
                <Insets top="20.0" left="20.0"/>
            </StackPane.margin>
        </Button>
        <Label fx:id="scoreLabel" styleClass="score-header-label" text="" StackPane.alignment="TOP_LEFT" visible="false" managed="false">
            <StackPane.margin>
                <Insets top="20.0" left="74.0"/>
            </StackPane.margin>
        </Label>
    </children>
</StackPane>